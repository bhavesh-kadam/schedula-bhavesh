// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

generator erd {
  provider = "prisma-erd-generator"
  output = "../ERD.svg"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DOCTOR
  PATIENT
}

enum ActiveStatus {
  ACTIVE
  ON_LEAVE
  RETIRED
}

enum Gender {
  MALE
  FEMALE
  TRANSGENDER
}

enum BloodGroup {
  O_POSITIVE
  A_POSITIVE
  B_POSITIVE
  AB_POSITIVE

  O_NEGATIVE
  A_NEGATIVE
  B_NEGATIVE
  AB_NEGATIVE
}

enum AppointmentStatus {
  BOOKED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id String @id @default(uuid())
  firstName String
  lastName String
  mobileNo String
  email String @unique
  dob DateTime
  gender Gender

  hash String
  role Role @default(PATIENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  patient Patient?
  doctor Doctor?

  notification Notification[]
  refreshToken RefreshToken[]

  @@index([role])
}

model Patient {
  id String @id @default(uuid())
  pid String @unique
  bloodGroup BloodGroup?
  pastIllness String? @db.Text

  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointment Appointment[]

  @@index([userId])
}


model Doctor {
  id String @id @default(uuid())
  licenseNo String @unique
  specialization String
  qualification String
  yearOfExperience Int
  consultationFee Int
  profileDetails String? @db.Text

  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeStatus ActiveStatus @default(ACTIVE)
  appointment Appointment[]
  availability Availability[]

  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

model Appointment {
  id String @id @default(uuid())

  patientId String
  patient Patient @relation(fields: [patientId], references: [id])

  doctorId String
  doctor Doctor @relation(fields: [doctorId], references: [id])

  startTime DateTime
  endTime DateTime

  appointmentStatus AppointmentStatus @default(BOOKED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([doctorId])
  @@index([patientId])
  @@unique([patientId, doctorId, startTime, endTime])
}

model Availability {
  id String @id @default(uuid())

  doctorId String
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  dayOfWeek Day
  startHour Int
  endHour Int

  @@index([doctorId])

  @@unique([doctorId, dayOfWeek])
  @@unique([doctorId, dayOfWeek, startHour, endHour])
}


model Notification {
  id String @id @default(uuid())

  userId String
  user User @relation(fields: [userId], references: [id])

  title String
  message String

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
}

model RefreshToken {
  id String @id @default(uuid())
  tokenHash String @unique
  user User @relation(fields: [userId], references: [id])
  userId String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
}







