// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DOCTOR
  PATIENT
}

enum ActiveStatus {
  ACTIVE
  ON_LEAVE
  RETIRED
}

enum Gender {
  MALE
  FEMALE
  TRANSGENDER
}

enum BloodGroup {
  O_POSITIVE
  A_POSITIVE
  B_POSITIVE
  AB_POSITIVE

  O_NEGATIVE
  A_NEGATIVE
  B_NEGATIVE
  AB_NEGATIVE
}

enum AppointmentStatus {
  BOOKED
  COMPLETED
  CANCELLED_BY_PATIENT
  CANCELLED_BY_DOCTOR
  RESCHEDULED
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum OverrideType {
  MODIFIED
  UNAVAILABLE
}

enum SchedulingType {
  STREAM
  WAVE
}

enum NotificationType {
  APPOINTMENT_BOOKED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_REMINDER
  FOLLOW_UP_REMINDER
}

model User {
  id String @id @default(uuid())
  firstName String
  lastName String
  mobileNo String
  email String @unique
  dob DateTime
  gender Gender

  hash String
  role Role @default(PATIENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  patient Patient?
  doctor Doctor?

  refreshToken RefreshToken[]

  @@index([role])
}

model Patient {
  id String @id @default(uuid())
  pid String @unique
  bloodGroup BloodGroup?
  pastIllness String? @db.Text

  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointment Appointment[]
  notification Notification[]

  @@index([userId])
}


model Doctor {
  id String @id @default(uuid())
  licenseNo String @unique
  specialization String
  qualification String
  yearOfExperience Int
  consultationFee Int
  profileDetails String? @db.Text

  schedulingType   SchedulingType @default(STREAM)
  slotDuration     Int            @default(15) // Used for STREAM
  bufferTime       Int            @default(0)  // Used for STREAM (in minutes)
  maxWaveCapacity  Int            @default(5)  // Used for WAVE

  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeStatus ActiveStatus @default(ACTIVE)
  appointment Appointment[]
  recurringAvailability RecurringAvailability[]
  customAvailability    CustomAvailability[]

  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

model Appointment {
  id String @id @default(uuid())

  patientId String
  patient Patient @relation(fields: [patientId], references: [id])

  doctorId String
  doctor Doctor @relation(fields: [doctorId], references: [id])

  startTime DateTime
  endTime DateTime

  tokenNumber Int?

  appointmentStatus AppointmentStatus @default(BOOKED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([doctorId])
  @@index([patientId])
  @@unique([patientId, doctorId, startTime, endTime])
}

model RecurringAvailability {
  id       String @id @default(uuid())
  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  dayOfWeek Day
  startTime String // E.g., "10:00" (HH:mm format makes time-overlap math easy)
  endTime   String // E.g., "13:00"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
  @@index([dayOfWeek])
}

model CustomAvailability {
  id       String @id @default(uuid())
  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  date         DateTime     // The specific date (e.g., 2026-06-15)
  overrideType OverrideType @default(MODIFIED)
  
  // Optional times: If overrideType is UNAVAILABLE, these can be null
  startTime    DateTime?    
  endTime      DateTime?    

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
  @@index([date])
}


model Notification {
  id String @id @default(uuid())

  patientId String
  patient Patient @relation(fields: [patientId], references: [id])

  title String
  message String

  type NotificationType

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
}

model RefreshToken {
  id String @id @default(uuid())
  tokenHash String @unique
  user User @relation(fields: [userId], references: [id])
  userId String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
}






